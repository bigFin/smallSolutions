---
interface Props {
  href: string;
  title: string;
  summary: string;
  meta: string;
  tags?: string[];
}

const { href, title, summary, meta, tags = [] } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const resolvedHref = href === "/" ? import.meta.env.BASE_URL : `${baseUrl}${href.replace(/^\//, "")}`;
---

<article class="section-card">
  <a class="section-card__title" href={resolvedHref}>{title}</a>
  <p class="section-card__meta">{meta}</p>
  <p class="section-card__summary">{summary}</p>
  {tags.length > 0 && (
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</article>

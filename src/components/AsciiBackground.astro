<canvas id="ascii-canvas"></canvas>

<script>
  import * as THREE from "three/webgpu";
  import { buildAsciiMaterial } from "../lib/ascii-material.ts";
  import { uniform, float, select } from "three/tsl";
  import { getTheme } from "../lib/themes";
  import { SITE_CONFIG } from "../lib/config";
  import * as Shaders from "../lib/shaders/modes";
  import { ChromeLabSpectrogram } from "../lib/backgrounds/spectrogram/chrome-lab-spectrogram";

  async function init() {
    const canvas = document.getElementById("ascii-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const supportsWebGPU = !!navigator.gpu && (await (async () => {
      try {
        const adapter = await navigator.gpu.requestAdapter();
        return !!adapter;
      } catch (e) {
        return false;
      }
    })());

    if (!supportsWebGPU) {
      console.warn("WebGPU not supported or secure context required.");
      const msg = document.createElement("div");
      msg.style.position = "fixed";
      msg.style.bottom = "10px";
      msg.style.right = "10px";
      msg.style.padding = "5px 10px";
      msg.style.background = "rgba(255, 0, 0, 0.1)";
      msg.style.color = "var(--muted)";
      msg.style.fontSize = "10px";
      msg.innerText = "WEBGL/STATIC FALLBACK";
      document.body.appendChild(msg);
      return;
    }

    const renderer = new THREE.WebGPURenderer({
      canvas,
      antialias: false,
      alpha: true,
    });
    try {
      await renderer.init();
    } catch (e) {
      console.error("WebGPU Renderer init failed:", e);
      return;
    }

    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(window.innerWidth, window.innerHeight);

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

    // 1. Generate Character Atlas (Mixed classic, block, and Braille)
    const charList = " .:-=+*#%@░▒▓█⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏⠐⠑⠒⠓⠔⠕⠖⠗⠘⠙⠚⠛⠜⠝⠞⠟⠠⠡⠢⠣⠤⠥⠦⠧⠨⠩⠪⠫⠬⠭⠮⠯⠰⠱⠲⠳⠴⠵⠶⠷⠸⠹⠺⠻⠼⠽⠾⠿".split("").slice(0, 64);
    const tileSize = 32;
    const atlasCols = 8;
    const atlasRows = 8; 
    const atlasWidth = atlasCols * tileSize;
    const atlasHeight = atlasRows * tileSize;

    const atlasCanvas = document.createElement("canvas");
    atlasCanvas.width = atlasWidth;
    atlasCanvas.height = atlasHeight;
    const ctx = atlasCanvas.getContext("2d");
    if (ctx) {
      ctx.fillStyle = "black";
      ctx.fillRect(0, 0, atlasWidth, atlasHeight);
      ctx.font = `bold ${tileSize * 0.85}px "Iosevka Aile", "Iosevka", monospace`;
      ctx.fillStyle = "white";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";

      charList.forEach((char, i) => {
        const x = (i % atlasCols) * tileSize + tileSize / 2;
        const y = Math.floor(i / atlasCols) * tileSize + tileSize / 2;
        ctx.fillText(char, x, y);
      });
    }

    const atlasTexture = new THREE.CanvasTexture(atlasCanvas);
    atlasTexture.minFilter = THREE.NearestFilter;
    atlasTexture.magFilter = THREE.NearestFilter;

    // 2. Theme Handling
    const gradientCanvas = document.createElement("canvas");
    gradientCanvas.width = 256;
    gradientCanvas.height = 1;
    const gCtx = gradientCanvas.getContext("2d");
    const gradientTexture = new THREE.CanvasTexture(gradientCanvas);

    const updateThemeAssets = (themeId: string) => {
      const config = getTheme(themeId);
      
      if (gCtx) {
        const grad = gCtx.createLinearGradient(0, 0, 256, 0);
        config.gradient.forEach((color, i) => {
          grad.addColorStop(i / (config.gradient.length - 1), color);
        });
        gCtx.fillStyle = grad;
        gCtx.fillRect(0, 0, 256, 1);
        gradientTexture.needsUpdate = true;
      }

      if (emailDyeColorLowUniform) {
        emailDyeColorLowUniform.value.set(...config.dye.low);
        emailDyeColorMidUniform.value.set(...config.dye.mid);
        emailDyeColorHighUniform.value.set(...config.dye.high);
        emailDyeColorPeakUniform.value.set(...config.dye.peak);
      }
    };

    // 3. Create a dynamic source texture using Nodes
    const noiseTarget = new THREE.RenderTarget(512, 512);
    const noiseScene = new THREE.Scene();
    const noiseMaterial = new THREE.MeshBasicNodeMaterial();
    
    const noiseTime = uniform(float(0));
    const mousePosUniform = uniform(new THREE.Vector2(0.5, 0.5));
    
    // Initial mode from localStorage or config
    const normalizeMode = (mode: string | null | undefined) => {
      const cleanMode = mode?.trim();
      if (!cleanMode) return SITE_CONFIG.defaultShaderMode;
      const lowerMode = cleanMode.toLowerCase();
      if (lowerMode === "syntheticspectrogram") return "syntheticSpectrogram";
      return lowerMode;
    };
    const initialMode = normalizeMode(localStorage.getItem("shader-mode"));
    const modeMap: Record<string, number> = { smoke: 0, warp: 1, grid: 2, topo: 3, lines: 4, lines2: 5, vibe: 6, stochastic: 7, nexus: 8, spectrogram: 9, syntheticSpectrogram: 10 };
    let activeMode = initialMode;
    const modeIndex = uniform(float(modeMap[initialMode] ?? 0)); 
    
    // --- MODE COMPOSITE ---
    const finalNoise = select(
      modeIndex.equal(0),
      Shaders.smokeShader(noiseTime, mousePosUniform),
      select(
        modeIndex.equal(1),
        Shaders.warpShader(noiseTime, mousePosUniform),
        select(
          modeIndex.equal(2),
          Shaders.gridShader(noiseTime, mousePosUniform),
          select(
            modeIndex.equal(3),
            Shaders.topoShader(noiseTime, mousePosUniform),
            select(
              modeIndex.equal(4),
              Shaders.topoLinesShader(noiseTime, mousePosUniform),
              select(
                modeIndex.equal(5),
                Shaders.topoLines2Shader(noiseTime, mousePosUniform),
                select(
                  modeIndex.equal(6),
                  Shaders.vibeShader(noiseTime, mousePosUniform),
                  select(
                    modeIndex.equal(7),
                    Shaders.stochasticShader(noiseTime, mousePosUniform),
                    select(
                      modeIndex.equal(8),
                      Shaders.nexusShader(noiseTime, mousePosUniform),
                      Shaders.syntheticSpectrogramShader(noiseTime, mousePosUniform)
                    )
                  )
                )
              )
            )
          )
        )
      )
    );
    
    noiseMaterial.colorNode = finalNoise;
    
    const noiseQuad = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), noiseMaterial);
    noiseScene.add(noiseQuad);

    const spectrogramBackground = new ChromeLabSpectrogram({
      palette: SITE_CONFIG.spectrogramPalette,
    });

    window.addEventListener("spectrogram-microphone-stream", (event: any) => {
      spectrogramBackground.setStream(event.detail).catch((error) => {
        console.warn("Could not connect microphone stream to spectrogram.", error);
      });
    });

    // 4. Uniforms (Grid size adjusted for chunkier look)
    const viewportSizeUniform = uniform(new THREE.Vector2(window.innerWidth, window.innerHeight));
    const gridSizeUniform = uniform(new THREE.Vector2(window.innerWidth / 8, window.innerHeight / 16));
    const gridOriginUniform = uniform(new THREE.Vector2(0, 0));
    const gridDisplaySizeUniform = uniform(new THREE.Vector2(window.innerWidth, window.innerHeight));
    const displayCellSizeUniform = uniform(new THREE.Vector2(8, 16));
    const atlasSizeUniform = uniform(new THREE.Vector2(atlasWidth, atlasHeight));
    const tileSizeUniform = uniform(new THREE.Vector2(tileSize, tileSize));
    const atlasColsUniform = uniform(float(atlasCols));
    const gradientIndexUniform = uniform(float(0));
    const debugTimeUniform = uniform(float(0));
    const emailDyeDebugEnabledUniform = uniform(float(1.0));
    const emailDyeDebugCenterUniform = uniform(new THREE.Vector2(0.5, 0.5));
    const emailDyeDebugHalfSizeUniform = uniform(new THREE.Vector2(0.18, 0.18));
    const emailDyeColorLowUniform = uniform(new THREE.Vector3(0, 0, 0));
    const emailDyeColorMidUniform = uniform(new THREE.Vector3(0, 0, 0));
    const emailDyeColorHighUniform = uniform(new THREE.Vector3(0, 0, 0));
    const emailDyeColorPeakUniform = uniform(new THREE.Vector3(0, 0, 0));

    // Listen for mode changes
    window.addEventListener("background-mode-change", (e: any) => {
      const mode = normalizeMode(e.detail);
      activeMode = mode;
      if (mode === "smoke") modeIndex.value = 0;
      if (mode === "warp") modeIndex.value = 1;
      if (mode === "grid") modeIndex.value = 2;
      if (mode === "topo") modeIndex.value = 3;
      if (mode === "lines") modeIndex.value = 4;
      if (mode === "lines2") modeIndex.value = 5;
      if (mode === "vibe") modeIndex.value = 6;
      if (mode === "stochastic") modeIndex.value = 7;
      if (mode === "nexus") modeIndex.value = 8;
      if (mode === "spectrogram") modeIndex.value = 9;
      if (mode === "syntheticSpectrogram") modeIndex.value = 10;
    });

    // Initialize theme
    const savedTheme = localStorage.getItem("theme") || SITE_CONFIG.defaultTheme;
    updateThemeAssets(savedTheme);

    // 5. Material
    const material = buildAsciiMaterial({
      atlasTexture,
      glyphTexture: noiseTarget.texture,
      colorTexture: noiseTarget.texture,
      sourceTexture: noiseTarget.texture,
      gradientTexture,
      gradientRowCount: 1,
      useRampDither: true,
      useGradientSignal: true,
      invertGradient: false,
      glyphRampIndices: [0, 4, 10, 13, 32, 63], 
      viewportSizeUniform,
      gridSizeUniform,
      gridOriginUniform,
      gridDisplaySizeUniform,
      displayCellSizeUniform,
      atlasSizeUniform,
      tileSizeUniform,
      atlasColsUniform,
      gradientIndexUniform,
      debugTimeUniform,
      emailDyeDebugEnabledUniform,
      emailDyeDebugCenterUniform,
      emailDyeDebugHalfSizeUniform,
      emailDyeColorLowUniform,
      emailDyeColorMidUniform,
      emailDyeColorHighUniform,
      emailDyeColorPeakUniform,
    });

    const quad = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
    scene.add(quad);

    let targetMouseX = 0.5;
    let targetMouseY = 0.5;
    let currentMouseX = 0.5;
    let currentMouseY = 0.5;
    let orientationActive = false;

    window.addEventListener("mousemove", (e) => {
      orientationActive = false;
      targetMouseX = e.clientX / window.innerWidth;
      targetMouseY = 1.0 - (e.clientY / window.innerHeight);
    });

    window.addEventListener("deviceorientation", (e) => {
      if (e.beta == null && e.gamma == null) return;

      orientationActive = true;
      const tiltX = Math.max(-1, Math.min(1, (e.gamma ?? 0) / 35));
      const tiltY = Math.max(-1, Math.min(1, ((e.beta ?? 45) - 45) / 45));
      targetMouseX = 0.5 + tiltX * 0.42;
      targetMouseY = 0.5 - tiltY * 0.42;
    });

    function animate(time: number) {
      const t = time / 1000;
      noiseTime.value = t;
      debugTimeUniform.value = t;

      const inputEase = orientationActive ? 0.09 : 0.05;
      currentMouseX += (targetMouseX - currentMouseX) * inputEase;
      currentMouseY += (targetMouseY - currentMouseY) * inputEase;
      emailDyeDebugCenterUniform.value.set(currentMouseX, currentMouseY);
      emailDyeDebugEnabledUniform.value = activeMode === "spectrogram" ? 0 : 1;
      mousePosUniform.value.set(currentMouseX, currentMouseY);

      if (activeMode === "spectrogram") {
        spectrogramBackground.update(time);
      } else {
        quad.material = material;
        renderer.setRenderTarget(noiseTarget);
        renderer.render(noiseScene, camera);
        renderer.setRenderTarget(null);
      }

      if (activeMode === "spectrogram") {
        renderer.render(spectrogramBackground.scene, spectrogramBackground.camera);
      } else {
        renderer.render(scene, camera);
      }
      requestAnimationFrame(animate);
    }

    window.addEventListener("resize", () => {
      const w = window.innerWidth;
      const h = window.innerHeight;
      renderer.setSize(w, h);
      spectrogramBackground.resize(w, h);
      viewportSizeUniform.value.set(w, h);
      gridDisplaySizeUniform.value.set(w, h);
      gridSizeUniform.value.set(w / 8, h / 16);
    });

    // Theme Mutation Observer
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.attributeName === "data-theme") {
          const theme = document.documentElement.dataset.theme || "everforest-light";
          updateThemeAssets(theme);
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true });

    requestAnimationFrame(animate);
  }

  init().catch((err) => console.error("WebGPU Init failed:", err));
</script>

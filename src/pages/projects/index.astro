---
import { getCollection } from "astro:content";
import SectionCard from "../../components/SectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const work = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects | smallSolutions">
  <section class="content-section">
    <div class="section-heading">
      <h1>Projects</h1>
      <p class="section-copy">
        Systems, instruments, and translational builds.
      </p>
    </div>
    <div class="card-grid">
      {work.map((entry) => (
        <SectionCard
          href={`/projects/${entry.slug}/`}
          title={entry.data.title}
          summary={entry.data.summary}
          meta={entry.data.period}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>

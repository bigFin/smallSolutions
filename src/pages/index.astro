---
import { getCollection } from "astro:content";
import SectionCard from "../components/SectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredWork = (await getCollection("work"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const writing = (await getCollection("writing"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const resumeHref = `${baseUrl}resume/`;
---

<BaseLayout title="smallSolutions">
  <section class="hero-panel">
    <div class="hero-panel__inner">
      <h1>Hardware, data, and production systems.</h1>
    </div>
    <div class="hero-panel__grid">
      <div>
        <p class="stat-label">Links</p>
        <p class="stat-copy">
          <a href="https://github.com/bigFin">GitHub</a>,
          <a href="mailto:finlay@smallsolutions.ca">email</a>,
          <a href={resumeHref}>resume</a>
        </p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>Projects</h2>
    </div>
    <div class="card-grid">
      {featuredWork.map((entry) => (
        <SectionCard
          href={`/projects/${entry.slug}/`}
          title={entry.data.title}
          summary={entry.data.summary}
          meta={entry.data.period}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>Writing</h2>
    </div>
    <div class="card-grid">
      {writing.map((entry) => (
        <SectionCard
          href={`/writing/${entry.slug}/`}
          title={entry.data.title}
          summary={entry.data.summary}
          meta={entry.data.date}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="content-section content-section--fun">
    <div class="section-heading">
      <h2>Just for fun</h2>
      <p class="section-copy">
        Shells, shaders, and other detours live on GitHub.
      </p>
    </div>
  </section>
</BaseLayout>
